{
    "name": "uimodule",
    "version": "0.0.1",
    "private": true,
    "description": "uimodule description",
    "keywords": [
        "ui5",
        "openui5",
        "sapui5"
    ],
    "main": "webapp/index.html",
    "devDependencies": {
        "@openui5/types": "~1.148",
        "@sap-ux/eslint-plugin-fiori-tools": "^10",
        "@sap/ux-specification": "^1.144",
        "@sap/ux-ui5-tooling": "1",
        "@sapui5/types": "~1.148",
        "@typescript-eslint/eslint-plugin": "^8",
        "@typescript-eslint/parser": "^8",
        "@ui5/cli": "^4",
        "@ui5/linter": "latest",
        "@ui5/ts-interface-generator": "^0",
        "@wdio/cli": "^9",
        "@wdio/local-runner": "^9",
        "@wdio/mocha-framework": "^9",
        "@wdio/spec-reporter": "^9",
        "ts-node": "^10",
        "typescript": "^6",
        "ui5-task-zipper": "^3",
        "ui5-test-runner": "^5",
        "ui5-tooling-modules": "^3",
        "ui5-tooling-transpile": "^3",
        "wdio-ui5-service": "^3"
    },
    "scripts": {
        "start": "ui5 serve --config=ui5.yaml --open index.html",
        "build": "ui5 build",
        "lint": "eslint ./",
        "ts-typecheck": "tsc --noEmit",
        "prestart": "npm run ts-typecheck",
        "prebuild": "npm run ts-typecheck",
        "ui5lint": "ui5lint",
        "qunit": "fiori run --open test/unitTests.qunit.html",
        "wdi5": "wdio run ./webapp/test/e2e/wdio.conf.ts",
        "test-runner": "ui5-test-runner --url http://localhost:4004/uimodule/test/testsuite.qunit.html --report-dir webapp/report"
    },
    "sapux": true,
    "dependencies": {
        "gsap": "^3",
        "three": "^0"
    }
}

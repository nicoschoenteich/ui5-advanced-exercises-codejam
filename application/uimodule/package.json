{
  "name": "uimodule",
  "version": "0.0.1",
  "description": "uimodule description",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "devDependencies": {
    "@openui5/types": "^1.149.1",
    "@sap-ux/eslint-plugin-fiori-tools": "^10.0.0",
    "@sap/ux-ui5-tooling": "1",
    "@sapui5/types": "~1.148.0",
    "@ui5/cli": "^4.0.33",
    "@ui5/linter": "latest",
    "@ui5/ts-interface-generator": "^0.11.1",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "eslint": "^10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "ui5-task-zipper": "^3",
    "ui5-test-runner": "^5.13.1",
    "ui5-tooling-modules": "^3.37.7",
    "ui5-tooling-transpile": "^3.10.0",
    "wdio-ui5-service": "^3.0.10"
  },
  "scripts": {
    "start": "ui5 serve --config=ui5.yaml --open index.html",
    "build": "ui5 build self-contained --all --include-task generateVersionInfo --config=ui5.yaml --clean-dest --dest dist",
    "lint": "eslint ./",
    "ts-typecheck": "tsc --noEmit",
    "prestart": "npm run ts-typecheck",
    "prebuild": "npm run ts-typecheck",
    "ui5lint": "ui5lint",
    "qunit": "fiori run --open test/unitTests.qunit.html",
    "opa5": "fiori run --open test/opaTests.qunit.html",
    "wdi5": "wdio run ./webapp/test/e2e/wdio.conf.ts",
    "test-runner": "ui5-test-runner --url http://localhost:4004/uimodule/test/testsuite.qunit.html --report-dir webapp/report"
  },
  "sapux": true,
  "dependencies": {
    "gsap": "^3.15.0",
    "three": "^0.185.1"
  }
}
